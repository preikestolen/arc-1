# ARC-1 — Environment Variables (v0.7 — authorization refactor)
#
# The authorization model uses POSITIVE OPT-INS (`SAP_ALLOW_*=true` to enable a
# capability). Defaults are restrictive. Every mutation requires BOTH the matching
# server flag AND the user's scope (when HTTP auth is enabled).
#
# Copy this file to `.env`, uncomment the section that matches your scenario, and
# fill in connection details. See docs_page/authorization.md for the full model.

# ═══════════════════════════════════════════════════════════════════════════
# SAP connection
# ═══════════════════════════════════════════════════════════════════════════
SAP_URL=http://sapnwas.example.com:8000
SAP_USER=DEVELOPER
SAP_PASSWORD=YOUR_PASSWORD
SAP_CLIENT=100
SAP_LANGUAGE=EN
# SAP_INSECURE=true  # Skip TLS verification — dev/test only

# Alternative: BTP ABAP Environment (service key)
# SAP_BTP_SERVICE_KEY_FILE=/path/to/service-key.json
# SAP_BTP_SERVICE_KEY='{"url":"...","uaa":{...}}'

# ═══════════════════════════════════════════════════════════════════════════
# MCP transport
# ═══════════════════════════════════════════════════════════════════════════
SAP_TRANSPORT=stdio              # or: http-streamable
# ARC1_PORT=8080                 # when SAP_TRANSPORT=http-streamable

# ── Read-only local/admin UI ──
# Experimental and off by default. Use `local` for a loopback sidecar next to
# stdio clients, or `web` to mount `/ui` on the HTTP server.
# ARC1_UI=off                    # off|local|web (true/false also accepted)
# ARC1_UI_ADDR=127.0.0.1:8711    # sidecar bind address for ARC1_UI=local
# ARC1_UI_OPEN=false             # open the local UI in a browser after startup

# ── Browser-based MCP clients (CORS) ──
# CORS is OFF by default. Native MCP clients (Claude Desktop, Cursor, VS Code,
# Copilot Studio) don't need this — they use native HTTP, not the browser fetch
# API. Set this only if a browser UI calls /mcp directly. Comma-separated, exact
# match, no wildcards. Pairs with `credentials: true`, so origins must be exact.
# ARC1_ALLOWED_ORIGINS=https://your-ui.example.com,https://other.example.com

# ═══════════════════════════════════════════════════════════════════════════
# Safety / authorization — pick ONE recipe below (comment out the others)
# ═══════════════════════════════════════════════════════════════════════════

# ── Recipe 1: SAFE DEFAULTS (read-only, no data preview, no SQL, $TMP only) ──
# This is the default. All SAP_ALLOW_* are implicitly false. No config needed.
# Object reads work; writes, transport mutations, git mutations, table data
# preview, and freestyle SQL are all blocked.

# ── Recipe 2: DEVELOPER MODE — writes to $TMP/Z* (no data preview, no SQL) ──
# SAP_ALLOW_WRITES=true
# SAP_ALLOWED_PACKAGES=$TMP,Z*

# ── Recipe 3: DEVELOPER + TRANSPORTS — write code + manage CTS ──
# SAP_ALLOW_WRITES=true
# SAP_ALLOWED_PACKAGES=$TMP,Z*
# SAP_ALLOW_TRANSPORT_WRITES=true

# ────────────── Recipe 4: DEVELOPER + DATA PREVIEW ──────────────
# WARNING: SAP_ALLOW_DATA_PREVIEW enables `SAPRead(type=TABLE_CONTENTS)` —
# named application-table content reads. This sits OUTSIDE the SAP API Policy,
# which excludes "programmatic reading of application tables or export of
# business data". Enable only for development scenarios that genuinely require
# it, against your SAP contract and your data-protection rules. See README
# "ADT API Status and Strategy".
# SAP_ALLOW_WRITES=true
# SAP_ALLOWED_PACKAGES=$TMP,Z*
# SAP_ALLOW_DATA_PREVIEW=true

# ───────── Recipe 5: DEVELOPER + FREESTYLE SQL (implies data preview) ─────────
# WARNING: SAP_ALLOW_FREE_SQL enables `SAPQuery` — freestyle ABAP SQL against
# the SAP backend. This sits OUTSIDE the SAP API Policy, which excludes "SQL
# execution against SAP development tooling" scope (which excludes "SQL
# execution against SAP backend systems"). Enable only for development
# scenarios that genuinely require it, against your SAP contract and your
# data-protection rules. See README "ADT API Status and Strategy".
# SAP_ALLOW_WRITES=true
# SAP_ALLOWED_PACKAGES=$TMP,Z*
# SAP_ALLOW_DATA_PREVIEW=true
# SAP_ALLOW_FREE_SQL=true

# ── Recipe 6: DEVELOPER + GIT (abapGit/gCTS writes) ──
# SAP_ALLOW_WRITES=true
# SAP_ALLOWED_PACKAGES=$TMP,Z*
# SAP_ALLOW_GIT_WRITES=true

# ── Recipe 7: FULL LOCAL DEV (everything on, any package) ──
# SAP_ALLOW_WRITES=true
# SAP_ALLOW_DATA_PREVIEW=true
# SAP_ALLOW_FREE_SQL=true
# SAP_ALLOW_TRANSPORT_WRITES=true
# SAP_ALLOW_GIT_WRITES=true
# SAP_ALLOWED_PACKAGES=*

# ── BTP / Steampunk (ABAP Environment) note ──────────────────────
# On the SAP BTP ABAP Environment, the default `$TMP` cannot host objects (POST → 403
# ExceptionResourceNoAccess), and the booster-provided `ZLOCAL` is a STRUCTURE package
# that also cannot contain development objects. Create a regular (development) sub-package
# under ZLOCAL in ADT/Eclipse and point the allowlist at it:
# SAP_ALLOW_WRITES=true
# SAP_ALLOWED_PACKAGES=Z*          # or the exact name of your cloud dev package
# (ARC-1 emits the cloud-correct create body automatically when systemType=btp.)

# ── Recipe 8: FINE-GRAINED DENIALS (SAP_DENY_ACTIONS) ──────────────────────
# Deny specific tools/actions even if scope + flag would allow.
# Grammar: tool-qualified only (Tool, Tool.action, Tool.glob*).
# NO cross-tool wildcards (`*.delete` is rejected).
# Inline CSV:
# SAP_DENY_ACTIONS=SAPWrite.delete,SAPManage.flp_*,SAPGit.push
# Or path to a JSON array file (auto-detected via `/`, `./`, `~/`, `../` prefix):
# SAP_DENY_ACTIONS=./deny-actions.json
# Example deny-actions.json content:
# ["SAPWrite.delete", "SAPManage.flp_*", "SAPGit.push"]
#
# Fail-fast: server aborts at startup if the value references an unknown
# tool/action or has invalid grammar.

# ═══════════════════════════════════════════════════════════════════════════
# MCP authentication (HTTP mode only)
# ═══════════════════════════════════════════════════════════════════════════

# ── Multi-key API auth (recommended for local dev with HTTP transport) ──
# Format: "key:profile,key:profile". Valid profiles:
#   viewer, viewer-data, viewer-sql, developer, developer-data, developer-sql, admin
# Each profile maps to a scope set AND a partial SafetyConfig that INTERSECTS
# the server ceiling (tight side wins field-by-field).
# ARC1_API_KEYS=viewer-key-abc:viewer,dev-key-def:developer
#
# HTTP transport refuses to start without API key, OIDC, or XSUAA auth unless
# this unsafe local/dev-only escape hatch is set explicitly.
# ARC1_ALLOW_HTTP_NO_AUTH=false

# ── OIDC (self-hosted IdP like Entra ID, Okta, etc.) ──
# SAP_OIDC_ISSUER=https://login.microsoftonline.com/TENANT/v2.0
# SAP_OIDC_AUDIENCE=arc-1
# SAP_OIDC_CLOCK_TOLERANCE=0

# ── XSUAA (BTP) ──
# SAP_XSUAA_AUTH=true
# (Scopes managed via xs-security.json role templates — see docs_page/xsuaa-setup.md)

# ═══════════════════════════════════════════════════════════════════════════
# Principal Propagation (per-user SAP auth via Cloud Connector)
# ═══════════════════════════════════════════════════════════════════════════
# SAP_PP_ENABLED=true
# SAP_PP_STRICT=true    # Optional JWT-only strict mode; also rejects API-key/non-JWT calls

# ═══════════════════════════════════════════════════════════════════════════
# Feature detection (auto/on/off — default auto)
# ═══════════════════════════════════════════════════════════════════════════
# SAP_FEATURE_ABAPGIT=auto
# SAP_FEATURE_GCTS=auto
# SAP_FEATURE_RAP=auto
# SAP_FEATURE_AMDP=auto
# SAP_FEATURE_UI5=auto
# SAP_FEATURE_TRANSPORT=auto
# SAP_FEATURE_HANA=auto
# SAP_FEATURE_UI5REPO=auto
# SAP_FEATURE_FLP=auto
# SAP_SYSTEM_TYPE=auto           # auto|btp|onprem
# SAP_ABAP_RELEASE=758           # Optional SAP_BASIS release override for local linting (e.g. 816 for ABAP Platform 2025)

# ═══════════════════════════════════════════════════════════════════════════
# Caching
# ═══════════════════════════════════════════════════════════════════════════
# ARC1_CACHE=auto                # auto|memory|sqlite|none
# ARC1_CACHE_FILE=.arc1-cache.db
# ARC1_CACHE_WARMUP=false
# ARC1_CACHE_WARMUP_PACKAGES=Z*,Y*

# ═══════════════════════════════════════════════════════════════════════════
# Lint / tooling
# ═══════════════════════════════════════════════════════════════════════════
# SAP_ABAPLINT_CONFIG=./abaplint.jsonc
# SAP_LINT_BEFORE_WRITE=true

# ═══════════════════════════════════════════════════════════════════════════
# Logging / concurrency / misc
# ═══════════════════════════════════════════════════════════════════════════
# ARC1_LOG_LEVEL=info            # debug|info|warn|error
# ARC1_LOG_FORMAT=text           # text|json
# Opt-in wire-level HTTP debug logging. Adds full request/response bodies and
# headers to http_request audit events. Sensitive headers redacted, bodies
# truncated at 64KB. Not for production. Default: false.
# ARC1_LOG_HTTP_DEBUG=false
# ARC1_MAX_CONCURRENT=10         # lower toward ~4 when several test runs share one small SAP system
# ARC1_TOOL_MODE=standard        # standard|hyperfocused
# ARC1_SCHEMA_NULLABLE_OPTIONALS=auto  # auto|off|on. auto/off keep portable plain schemas; set on only
#                                      # for tested OpenAI/Azure strict-mode clients that need nullable optionals (#360).
# SAP_VERBOSE=false

# ── Extensions (FEAT-61) — add your own Custom_* tools; see docs_page/extensions.md ──
# CSV of absolute LOCAL paths (.js code plugin or .json manifest), NOT npm names.
# ARC1_PLUGINS=/abs/path/to/plugin/dist/index.js
# Opt-in (default false): let plugin tools EXECUTE ABAP console classes (ctx.run.classRun).
# ALSO requires SAP_ALLOW_WRITES=true and a write-scoped tool. Default-off so enabling
# built-in writes never silently grants plugins code execution.
# SAP_ALLOW_PLUGIN_EXECUTE=false
# Opt-in (default false): let plugin tools WRITE (ctx.http.post/put/delete) to NON-ADT paths
# (OData /sap/opu/odata/…, custom ICF /sap/bc/http/…). ALSO requires SAP_ALLOW_WRITES=true and a
# write-scoped tool. Writes to /sap/bc/adt/… object endpoints are ALWAYS refused (no package-
# allowlist enforcement on a raw write). SAP_ALLOWED_PACKAGES does not constrain these calls.
# SAP_ALLOW_PLUGIN_RAW_WRITES=false

# ── Test runner (integration/e2e) — see docs/dev-guide.md "Testing — concurrent runs" ──
# These configure the TEST harness, not the server; only needed when running
# integration/e2e concurrently against one SAP system.
# TEST_RUN_ID                    # letters-only id stamped into generated object names. LEAVE UNSET for
#                                # an automatic per-run id (recommended). Pin only to make ONE run's
#                                # objects recognisable — never set the SAME value in two concurrent
#                                # worktrees, or their generated names collide.
# TEST_FILE_PARALLELISM=true     # opt into 2-file-parallel integration runs (default: sequential)

# ═══════════════════════════════════════════════════════════════════════════
# MIGRATED/REMOVED ENV VARS — these will error at startup in v0.7
# ═══════════════════════════════════════════════════════════════════════════
# SAP_READ_ONLY              → use SAP_ALLOW_WRITES (inverted)
# SAP_BLOCK_DATA             → use SAP_ALLOW_DATA_PREVIEW (inverted)
# SAP_BLOCK_FREE_SQL         → use SAP_ALLOW_FREE_SQL (inverted)
# SAP_ENABLE_TRANSPORTS      → use SAP_ALLOW_TRANSPORT_WRITES
# SAP_ENABLE_GIT             → use SAP_ALLOW_GIT_WRITES
# SAP_ALLOWED_OPS            → use SAP_DENY_ACTIONS (see Recipe 8 above)
# SAP_DISALLOWED_OPS         → use SAP_DENY_ACTIONS
# ARC1_PROFILE               → set individual SAP_ALLOW_* flags (recipes above)
# ARC1_API_KEY (single)      → use ARC1_API_KEYS="key:profile"
#
# See docs_page/updating.md#v07-authorization-refactor-breaking-change for
# the full migration guide.
