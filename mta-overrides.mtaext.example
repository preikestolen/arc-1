# ──────────────────────────────────────────────────────────────────────
# MTA Extension Descriptor — Environment-Specific Overrides (TEMPLATE)
#
# This is a tracked template. Copy it to a real file (which is gitignored
# by `.gitignore`) and fill in your landscape values:
#
#   cp mta-overrides.mtaext.example mta-overrides.mtaext
#   # edit mta-overrides.mtaext
#
# Then build + deploy with the extension applied:
#
#   npm run btp:build-deploy-ext
#   # or, manually:
#   mbt build
#   cf deploy mta_archives/arc1-mcp_<version>.mtar -e mta-overrides.mtaext
#
# Any property left commented uses the `mta.yaml` value unchanged. The two
# `SAP_BTP_*_DESTINATION` properties below are the only ones that have to
# be set — the base `mta.yaml` ships with placeholder destination names so
# deploying without an override fails fast at startup.
# ──────────────────────────────────────────────────────────────────────

_schema-version: "3.1"
ID: arc1-mcp-overrides
extends: arc1-mcp

modules:
  - name: arc1-mcp-server
    properties:
      # ── Destinations (REQUIRED override) ─────────────────────────────
      # BasicAuth destination for startup (feature probing, cache warmup)
      # SAP_BTP_DESTINATION: "my-basic-auth-destination"

      # PrincipalPropagation destination for per-user requests (with JWT)
      # SAP_BTP_PP_DESTINATION: "my-pp-destination"

      # ── Principal propagation behaviour ──────────────────────────────
      # Enable per-user principal propagation (default in mta.yaml: true)
      # SAP_PP_ENABLED: "true"

      # The base MTA uses the recommended strict default: API-key/non-JWT tool
      # calls are rejected. Set false for supported mixed PP/API-key operation;
      # JWT calls use PP and API-key calls use the shared destination identity.
      # SAP_PP_STRICT: "false"

      # ── Safety / Authorization ───────────────────────────────────────
      # Enable object mutations (create, update, delete)
      # SAP_ALLOW_WRITES: "true"

      # Enable named table data preview (SELECT * FROM <table>)
      # SAP_ALLOW_DATA_PREVIEW: "true"

      # Enable freestyle SQL execution
      # SAP_ALLOW_FREE_SQL: "true"

      # Enable transport mutations (release, create, add to transport).
      # Also requires SAP_ALLOW_WRITES=true.
      # SAP_ALLOW_TRANSPORT_WRITES: "true"

      # Enable abapGit / gCTS mutations (push, pull, clone). Also requires
      # SAP_ALLOW_WRITES=true.
      # SAP_ALLOW_GIT_WRITES: "true"

      # Restrict writes to these packages (comma-separated, supports
      # wildcards). Default in mta.yaml: "$TMP".
      # SAP_ALLOWED_PACKAGES: "Z*,Y*,$TMP"

      # Fine-grained per-action denial. Tool-qualified globs supported,
      # e.g. "SAPGit.*,SAPWrite.delete". See docs/authorization.md.
      # SAP_DENY_ACTIONS: "SAPGit.*"

      # ── Networking / public URL ──────────────────────────────────────
      # Override the public URL ARC-1 advertises in OAuth metadata (issuer,
      # authorize/token/register endpoints). Required when ARC-1 is reached
      # through a reverse proxy on a different hostname or under a base-path
      # prefix than the bound CF route.
      # ARC1_PUBLIC_URL: "https://gateway.example.com/arc1"

      # ── OAuth Dynamic Client Registration (DCR) ──────────────────────
      # Lifetime of an OAuth DCR `client_id` in seconds. Default: "0" (never
      # expire) — set in the base mta.yaml, because there is no per-client
      # revocation at any TTL and some MCP clients (Eclipse Copilot, Copilot
      # CLI) don't recover from `invalid_client`. Uncomment below ONLY to opt
      # into a finite TTL; positive values are clamped to [60s, 90d].
      # ARC1_OAUTH_DCR_TTL_SECONDS: "604800"   # e.g. 7 days

      # NOTE: ARC1_DCR_SIGNING_SECRET is intentionally NOT listed here.
      # The dedicated signing secret decouples DCR `client_id`s from the
      # XSUAA `clientsecret` so cached client_ids survive `cf deploy` — but
      # only if the secret itself survives `cf deploy`. Set it via:
      #
      #   cf set-env arc1-mcp-server ARC1_DCR_SIGNING_SECRET "$(openssl rand -base64 48)"
      #   cf restage arc1-mcp-server
      #
      # Env vars set with `cf set-env` survive `cf deploy`. MTA properties
      # under `modules[*].properties` are rewritten on every deploy, which
      # would rotate the signing secret on each deploy and invalidate every
      # cached client_id — defeating the whole purpose of having one.
      # See docs_page/xsuaa-setup.md "Stable DCR signing key" for the full
      # rationale.

      # ── CORS ─────────────────────────────────────────────────────────
      # Allow browser-based UIs to call /mcp directly. Not needed for
      # native MCP clients (Claude Desktop, Cursor, VS Code, Copilot
      # Studio). Comma-separated, exact origin match, no wildcards.
      # ARC1_ALLOWED_ORIGINS: "https://my-app.cfapps.eu10.hana.ondemand.com"

      # ── Read-only UI ─────────────────────────────────────────────────
      # Experimental and off by default. For browser access on BTP CF, deploy
      # with mta-ui-approuter.mtaext instead of uncommenting only this line:
      #
      #   npm run btp:build-deploy-ui-ext
      #
      # That extension enables ARC1_UI=web and activates the optional AppRouter,
      # which performs XSUAA login and forwards an admin-scoped JWT to ARC-1.
      # The deploy script writes an ignored mta-ui-deploy.mtaext by merging this
      # file with the UI activation, so your destination/route/xsappname values
      # stay in the same single extension descriptor passed to `cf deploy`.
      # ARC1_UI: "web"

      # ── Tool surface ─────────────────────────────────────────────────
      # Tool mode: "standard" (12 tools) or "hyperfocused" (1 universal
      # SAP tool, ~200 tokens — useful for token-tight clients).
      # ARC1_TOOL_MODE: "standard"

      # ── Cache warmup ─────────────────────────────────────────────────
      # Pre-warm the cache on startup via TADIR scan. Speeds up first-use
      # latency at the cost of slower startup and a TADIR read at boot.
      # ARC1_CACHE_WARMUP: "true"

      # Filter packages for warmup, comma-separated, wildcards allowed.
      # ARC1_CACHE_WARMUP_PACKAGES: "Z*,Y*"

      # ── Diagnostics ──────────────────────────────────────────────────
      # Attach full request/response bodies and headers to `http_request`
      # audit events. Sensitive headers redacted, bodies truncated at
      # 64KB. Not for production.
      # ARC1_LOG_HTTP_DEBUG: "true"

      # ── System Connection (rarely overridden) ────────────────────────
      # Override system type detection. Default in mta.yaml is "auto"; set
      # this only to force "btp" or "onprem".
      # SAP_SYSTEM_TYPE: "btp"

      # SAP client number (only when NOT using a destination)
      # SAP_CLIENT: "100"

      # SAP language
      # SAP_LANGUAGE: "EN"

      # Skip TLS certificate verification (default in mta.yaml: true, for
      # on-premise self-signed-cert landscapes). Override to "false" on
      # landscapes with proper CA-signed certificates.
      # SAP_INSECURE: "false"

    # ── Route host — pick your public URL (recommended) ──────────────
    # Base mta.yaml sets NO host, so the deploy service assigns a globally
    # unique but long auto-host (e.g.
    # myorg-1a2b3c4d-dev-myspace-arc1-mcp-server.cfapps.<region>...). To deploy
    # under a short URL you control — the one your MCP clients connect to — pin
    # `host:` here. Add a `parameters:` block to the arc1-mcp-server module
    # above (a sibling of `properties:`):
    #       parameters:
    #         host: arc1-mcp-prod    # -> https://arc1-mcp-prod.cfapps.<region>.../mcp
    # The host must be lowercase letters/digits/hyphens (no spaces/underscores)
    # AND free on the shared `cfapps.<region>.hana.ondemand.com` domain (it is
    # first-come-first-served across ALL subaccounts in that region) — pick a
    # customer/landscape-specific name like `arc1-mcp-teag` to avoid clashes.
    #
    # ── XSUAA xsappname (optional, independent of the route) ─────────
    # Base mta.yaml derives the XSUAA `xsappname` from the CF space via
    # `${space}` (unique within your subaccount — fine to leave as-is). Pin it
    # only if your space name isn't a valid xsappname or you want a fixed name.
    # Append this resource block (a sibling of `modules:`):
    #       resources:
    #         - name: arc1-xsuaa
    #           parameters:
    #             config:
    #               xsappname: arc1-mcp-prod

# ── Application logging (OFF by default — deprecated service) ───────────
# SAP Application Logging Service is deprecated (SAP Note 3557260; removed from
# Eligible Cloud Services 2025-07-31 — use SAP Cloud Logging instead), so the
# base mta.yaml ships it with `active: false` and does NOT create it. ARC-1
# logs to stderr regardless, so `cf logs` / `cf logs --recent` keep working.
# To re-enable CF log aggregation on a subaccount that still offers the
# service, uncomment this resource block (a sibling of `modules:`) to flip the
# resource active:
# resources:
#   - name: arc1-application-logs
#     active: true
